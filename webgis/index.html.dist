<!DOCTYPE html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <title>WebGIS Padang</title>
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
    <link
      rel="stylesheet"
      href="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/css/bootstrap.min.css"
    />
    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script>
    <script src="https://maxcdn.bootstrapcdn.com/bootstrap/3.4.1/js/bootstrap.min.js"></script>
    <style>
      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: Arial, sans-serif;
      }

      .container {
        display: flex;
        flex-direction: row;
        height: 100vh;
      }

      .map {
        flex: 2;
        min-height: 300px;
      }

      .sidebar {
        flex: 1;
        padding: 15px;
        overflow-y: auto;
        background: #f8f9fa;
        border-left: 1px solid #ccc;
      }

      .sidebar h2 {
        font-size: 18px;
        margin-top: 0;
      }

      .form-group {
        margin-bottom: 12px;
      }

      .form-group label {
        display: block;
        margin-bottom: 4px;
      }

      .form-group input,
      .form-group select {
        width: 100%;
        padding: 6px;
        border: 1px solid #ccc;
        border-radius: 4px;
      }

      @media (max-width: 768px) {
        .container {
          flex-direction: column;
        }

        .sidebar {
          border-left: none;
          border-top: 1px solid #ccc;
        }
      }
    </style>
  </head>

  <body>
    <div class="container">
      <div class="sidebar">
        <h2>Form Indikator</h2>

        <div class="form-group">
          <label for="indikator">Pilih Tahun</label>
          <select id="indikator">
            <option value="2023">2023</option>
            <option value="2024">2024</option>
            <option value="2025">Prediksi 2025</option>
          </select>
        </div>

        <h2>Data ASI Eklusif</h2>
        <table class="table table-bordered">
          <thead>
            <tr>
              <th>No</th>
              <th>Kecamatan</th>
              <th>Jumlah Data</th>
              <th>Persentase</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td>1</td>
              <td>-</td>
              <td>-</td>
              <td>-</td>
            </tr>
          </tbody>
        </table>
      </div>

      <div id="map" class="map"></div>
    </div>

    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
    <script src="webgis/js/app.js"></script>
  </body>
</html>
